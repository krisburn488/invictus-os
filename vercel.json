{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "frontend": {
      "root": "frontend/",
      "framework": "vite",
      "installCommand": "npm install",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "rewrites": [
        {
          "source": "/(.*)",
          "destination": "/index.html"
        }
      ]
    },
    "backend": {
      "root": "backend/",
      "framework": "fastapi",
      "entrypoint": "src.invictus_os.api.app:app",
      "installCommand": "pip install -e .",
      "functions": {
        "src/invictus_os/api/app.py": {
          "maxDuration": 30
        }
      }
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/agents/(.*)",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/content/(.*)",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/design/(.*)",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/reels/(.*)",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/schedule/(.*)",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/settings",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/docs",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/redoc",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/openapi.json",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "frontend"
      }
    }
  ]
}
