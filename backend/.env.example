# In local development, OpenAI credentials can be configured in the dashboard Settings page.
# In Vercel production, configure this as a backend project environment variable.
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: comma-free JSON list of exact frontend origins for CORS.
INVICTUS_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Optional: regex for deployed frontend origins. The default allows Vercel app domains.
INVICTUS_CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Optional: server-side bridge that can call the connected Higgsfield MCP generate_video tool.
# Without this, reel packages still generate and the dashboard shows a retryable setup message.
HIGGSFIELD_MCP_BRIDGE_URL=https://your-higgsfield-mcp-bridge.example.com/generate-video
